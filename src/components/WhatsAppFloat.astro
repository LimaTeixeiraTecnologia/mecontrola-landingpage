---
import { WHATSAPP_DUVIDAS_URL } from '../lib/content';
import Icon from './ui/Icon.astro';
---

<a
  href={WHATSAPP_DUVIDAS_URL}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Ficou com dúvidas? Fale conosco pelo WhatsApp"
  class="whatsapp-float"
>
  <Icon name="whatsapp" size={22} class="shrink-0" />
  <span>Ficou com dúvidas? Fale conosco</span>
</a>

<style>
  .whatsapp-float {
    position: fixed;
    bottom: 5.5rem; /* acima da MobileStickyBar no mobile */
    right: 1.25rem;
    z-index: 50;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: #1e8449; /* #25d366 falha WCAG AA — escurecer para 4.7:1 com branco */
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.65rem 1.1rem;
    border-radius: 9999px;
    box-shadow:
      0 4px 14px rgba(30, 132, 73, 0.55),
      0 2px 6px rgba(0, 0, 0, 0.3);
    text-decoration: none;
    transition:
      transform 0.15s ease,
      box-shadow 0.15s ease;
    white-space: nowrap;
  }

  .whatsapp-float:hover {
    transform: translateY(-2px);
    box-shadow:
      0 6px 20px rgba(30, 132, 73, 0.65),
      0 3px 8px rgba(0, 0, 0, 0.3);
  }

  .whatsapp-float:active {
    transform: translateY(0);
  }

  /* No desktop, posiciona mais abaixo (sem MobileStickyBar) */
  @media (min-width: 768px) {
    .whatsapp-float {
      bottom: 2rem;
      right: 2rem;
      font-size: 0.9rem;
      padding: 0.75rem 1.25rem;
    }
  }
</style>
