---
import { CNPJ, CONTACT_EMAIL, INSTAGRAM_URL } from '../lib/content';
import Icon from './ui/Icon.astro';
---

<footer class="text-center text-muted-foreground text-sm py-8 px-5 border-t border-border">
  <div class="inline-flex items-center gap-2 mb-3 font-extrabold text-[1.05rem]">
    <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true">
      <path
        d="M16 8 H48 A8 8 0 0 1 56 16 V36 A8 8 0 0 1 48 44 H30 L18 56 V44 H16 A8 8 0 0 1 8 36 V16 A8 8 0 0 1 16 8 Z"
        fill="#0D0D0D"
        stroke="#C6FF00"
        stroke-width="3.5"
        stroke-linejoin="round"></path>
      <ellipse cx="25" cy="23" rx="3.4" ry="5" fill="#FFFFFF"></ellipse>
      <path
        d="M35 21 q4.5 3.2 9 0.2"
        fill="none"
        stroke="#C6FF00"
        stroke-width="3"
        stroke-linecap="round"></path>
      <path
        d="M22 31 q10 9 20 0"
        fill="none"
        stroke="#C6FF00"
        stroke-width="3.4"
        stroke-linecap="round"></path>
    </svg>
    <span><span class="text-foreground">Me</span><span class="text-primary">Controla</span></span>
  </div>

  <p class="mb-2">Menos caos. Mais conquistas.</p>
  <p>© 2026 MeControla · CNPJ {CNPJ} · {CONTACT_EMAIL}</p>

  <a
    href={INSTAGRAM_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1 mt-3 text-muted-foreground hover:text-primary transition-colors"
  >
    <Icon name="instagram" size={16} />
    Instagram
  </a>
</footer>
