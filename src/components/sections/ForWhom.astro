---
import { forWhom } from '../../lib/content';
---

<section
  class="py-[56px]"
  style="background: linear-gradient(160deg, rgba(120,97,255,.18), rgba(13,13,13,0))"
>
  <div class="max-w-[1080px] mx-auto px-5">
    <div>
      <h2
        class="text-[1.7rem] md:text-[2.2rem] font-extrabold text-foreground"
        style="letter-spacing:-0.02em;line-height:1.15"
      >
        {forWhom.heading}
      </h2>
    </div>
    <ul class="quem-list max-w-[760px]">
      {forWhom.items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>
