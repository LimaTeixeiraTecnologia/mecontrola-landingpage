---
import { cn } from '../../lib/cn';

interface Props {
  featured?: boolean;
  as?: 'div' | 'article';
  class?: string;
}

const { featured = false, as: Tag = 'div', class: className } = Astro.props;

const classes = cn(
  'bg-card border rounded-2xl p-6 md:p-8',
  featured
    ? 'border-primary bg-[linear-gradient(180deg,rgba(198,255,0,.06),#1F1F1F)] shadow-[0_0_0_1px_#C6FF00,0_18px_40px_rgba(198,255,0,.08)]'
    : 'border-border',
  className,
);
---

<Tag class={classes}>
  <slot />
</Tag>
