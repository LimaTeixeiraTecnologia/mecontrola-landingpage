---
import { cn } from '../../lib/cn';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const classes = cn(
  'bg-surface/60 border border-border rounded-2xl p-6',
  'hover:border-accent/40 hover:shadow-[0_0_30px_-10px_var(--color-accent)]',
  'transition-all duration-200 motion-reduce:transition-none',
  className,
);
---

<div class={classes}>
  <slot />
</div>
