---
import { cn } from '../../lib/cn';

interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { tag, title, subtitle, align = 'left' } = Astro.props;
const isCentered = align === 'center';
---

<div class={cn('mb-12', isCentered && 'text-center')}>
  {
    tag && (
      <p
        class="text-primary text-xs font-bold uppercase mb-3 inline-block"
        style="letter-spacing: var(--tracking-wide)"
      >
        {tag}
      </p>
    )
  }
  <h2
    class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4"
    style="letter-spacing: var(--tracking-tight); line-height: 1.15"
  >
    {title}
  </h2>
  {
    subtitle && (
      <p class={cn('text-muted-foreground text-lg', isCentered && 'mx-auto max-w-2xl')}>
        {subtitle}
      </p>
    )
  }
</div>
