---
// WhatsApp brand colors used as arbitrary values — not part of MeControla design system
// WA palette: #0B141A (bg), #1F2C33 (header/incoming), #005C4B (outgoing), #00A884 (online)
---

<div
  aria-hidden="true"
  role="img"
  class="relative max-w-[330px] mx-auto bg-[#0B141A] rounded-[40px] p-[10px] shadow-[0_30px_60px_rgba(0,0,0,.5),0_0_0_2px_rgba(255,255,255,.06)]"
>
  <span
    class="absolute top-[8px] left-1/2 -translate-x-1/2 w-[120px] h-[26px] bg-black rounded-b-[18px] z-[3]"
    aria-hidden="true"></span>
  <div class="bg-[#0B141A] rounded-[31px] overflow-hidden">
    <!-- iOS Status Bar -->
    <div
      class="bg-[#1F2C33] flex justify-between items-center px-[22px] pt-[10px] pb-1 text-white text-[0.78rem] font-semibold"
      aria-hidden="true"
    >
      <span>9:41</span>
      <span class="inline-flex items-center gap-[5px]">
        <!-- signal -->
        <svg viewBox="0 0 18 12" width="17" height="11" aria-hidden="true">
          <rect x="0" y="6" width="3" height="6" rx="1" fill="#fff"></rect>
          <rect x="5" y="3" width="3" height="9" rx="1" fill="#fff"></rect>
          <rect x="10" y="0" width="3" height="12" rx="1" fill="#fff"></rect>
        </svg>
        <!-- wifi -->
        <svg viewBox="0 0 16 12" width="15" height="11" aria-hidden="true">
          <path
            d="M8 11.5a1.2 1.2 0 1 0 0-2.4 1.2 1.2 0 0 0 0 2.4Zm0-4.4a3.4 3.4 0 0 1 2.4 1l1.4-1.5a5.4 5.4 0 0 0-7.6 0l1.4 1.5A3.4 3.4 0 0 1 8 7.1Zm0-4.5a7.6 7.6 0 0 1 5.4 2.2l1.4-1.5a9.6 9.6 0 0 0-13.6 0l1.4 1.5A7.6 7.6 0 0 1 8 2.6Z"
            fill="#fff"></path>
        </svg>
        <!-- battery -->
        <svg viewBox="0 0 26 12" width="24" height="11" aria-hidden="true">
          <rect
            x="0.5"
            y="1"
            width="22"
            height="10"
            rx="2.5"
            fill="none"
            stroke="#fff"
            stroke-width="1"></rect>
          <rect x="2" y="2.5" width="17" height="7" rx="1.2" fill="#C6FF00"></rect>
          <rect x="23.5" y="4" width="1.5" height="4" rx=".5" fill="#fff"></rect>
        </svg>
      </span>
    </div>

    <!-- WhatsApp Header Bar -->
    <div class="bg-[#1F2C33] flex items-center gap-[10px] px-3 pt-[6px] pb-3">
      <span class="text-[#cfd8dc] text-[1.4rem] leading-none px-[2px]" aria-hidden="true">‹</span>
      <!-- Avatar: mascot face -->
      <div
        class="w-10 h-10 rounded-full bg-[#0D0D0D] border-[1.5px] border-[#C6FF00] grid place-items-center overflow-hidden flex-none"
      >
        <svg viewBox="0 0 64 64" width="30" height="30" aria-hidden="true">
          <path
            d="M16 8 H48 A8 8 0 0 1 56 16 V36 A8 8 0 0 1 48 44 H30 L18 56 V44 H16 A8 8 0 0 1 8 36 V16 A8 8 0 0 1 16 8 Z"
            fill="#0D0D0D"
            stroke="#C6FF00"
            stroke-width="3.5"
            stroke-linejoin="round"></path>
          <ellipse cx="25" cy="23" rx="3.4" ry="5" fill="#FFFFFF"></ellipse>
          <path
            d="M35 21 q4.5 3.2 9 0.2"
            fill="none"
            stroke="#C6FF00"
            stroke-width="3"
            stroke-linecap="round"></path>
          <path
            d="M22 31 q10 9 20 0"
            fill="none"
            stroke="#C6FF00"
            stroke-width="3.4"
            stroke-linecap="round"></path>
        </svg>
      </div>
      <div class="flex-1">
        <div class="font-bold text-[0.95rem] text-white">MeControla</div>
        <div class="text-[0.72rem] font-medium" style="color: #00A884">online</div>
      </div>
      <div class="inline-flex items-center gap-[14px] text-[#cfd8dc]" aria-hidden="true">
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="#cfd8dc"
          stroke-width="2"
        >
          <path d="M23 7l-7 5 7 5V7zM1 5h15v14H1z"></path>
        </svg>
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="#cfd8dc"
          stroke-width="2"
        >
          <path
            d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"
          ></path>
        </svg>
        <span
          class="inline-block w-[4px] h-[18px]"
          style="background: radial-gradient(circle at 2px 3px,#cfd8dc 1.6px,transparent 1.7px), radial-gradient(circle at 2px 9px,#cfd8dc 1.6px,transparent 1.7px), radial-gradient(circle at 2px 15px,#cfd8dc 1.6px,transparent 1.7px);"
          aria-hidden="true"></span>
      </div>
    </div>

    <!-- Chat Body -->
    <div
      class="px-[14px] py-[18px] flex flex-col gap-[10px] min-h-[340px] bg-[#0B141A]"
      style="background-image: radial-gradient(rgba(255,255,255,.025) 1px, transparent 1px); background-size: 18px 18px;"
    >
      <!-- Date pill -->
      <div
        class="self-center bg-[rgba(31,44,51,.85)] text-[#cfd8dc] text-[0.7rem] font-semibold px-3 py-[5px] rounded-lg my-1"
      >
        Hoje
      </div>

      <!-- Outgoing message -->
      <div
        class="self-end max-w-[80%] bg-[#005C4B] text-white px-3 py-[9px] rounded-2xl rounded-tr-[4px] text-[0.86rem] font-medium leading-[1.35]"
      >
        80 no cinema com a galera 🎬
        <div class="flex items-center justify-end gap-[5px] mt-[3px]">
          <span class="text-[0.62rem] text-[rgba(255,255,255,.5)]">21:34</span>
          <span class="text-[0.7rem] text-[#53bdeb] tracking-[-2px] font-bold">✓✓</span>
        </div>
      </div>

      <!-- Incoming message -->
      <div
        class="self-start max-w-[80%] bg-[#1F2C33] text-white px-3 py-[9px] rounded-2xl rounded-tl-[4px] text-[0.86rem] font-medium leading-[1.35]"
      >
        Pronto, lancei pra você 😉
        <div class="flex items-center justify-end gap-[5px] mt-[3px]">
          <span class="text-[0.62rem] text-[rgba(255,255,255,.5)]">21:34</span>
        </div>
      </div>

      <!-- Receipt card (incoming) -->
      <div
        class="self-start max-w-[90%] bg-[#1F2C33] text-white px-[14px] pt-3 pb-[9px] rounded-2xl rounded-tl-[4px] text-[0.83rem]"
      >
        <div class="flex justify-between items-baseline gap-[14px] py-[3px]">
          <span style="color:#A9B3BB" class="font-medium">Categoria</span>
          <span class="text-white font-bold whitespace-nowrap">Lazer</span>
        </div>
        <div class="flex justify-between items-baseline gap-[14px] py-[3px]">
          <span style="color:#A9B3BB" class="font-medium">Subcategoria</span>
          <span class="text-white font-bold whitespace-nowrap">Cinema</span>
        </div>
        <div class="flex justify-between items-baseline gap-[14px] py-[3px]">
          <span style="color:#A9B3BB" class="font-medium">Valor</span>
          <span class="text-white font-bold whitespace-nowrap">R$ 80,00</span>
        </div>
        <div class="h-px my-2" style="background: rgba(255,255,255,.08)"></div>
        <div class="flex justify-between items-baseline gap-[14px] py-[3px]">
          <span style="color:#A9B3BB" class="font-medium">Total usado em Lazer</span>
          <span class="text-white font-bold whitespace-nowrap">R$ 380,00</span>
        </div>
        <div class="flex justify-between items-baseline gap-[14px] py-[3px]">
          <span style="color:#A9B3BB" class="font-medium">Saldo disponível</span>
          <span class="font-bold whitespace-nowrap" style="color:#25D366">R$ 120,00</span>
        </div>
        <p class="mt-[10px] text-[0.82rem] leading-[1.45]" style="color:#E9EDEF">
          Ainda dá pra curtir o mês sem aperto 💚<br />Tá no ritmo, segue assim 🚀
        </p>
        <div class="flex items-center justify-end gap-[5px] mt-[3px]">
          <span class="text-[0.62rem] text-[rgba(255,255,255,.5)]">21:34</span>
        </div>
      </div>

      <!-- Typing indicator -->
      <div
        class="self-start bg-[#1F2C33] px-[14px] py-[10px] rounded-2xl rounded-tl-[4px] inline-flex gap-1 items-center"
        aria-hidden="true"
      >
        <span
          class="w-[6px] h-[6px] rounded-full bg-[#cfd8dc] opacity-50 animate-[dot_1.2s_ease-in-out_infinite]"
        ></span>
        <span
          class="w-[6px] h-[6px] rounded-full bg-[#cfd8dc] opacity-50 animate-[dot_1.2s_ease-in-out_0.15s_infinite]"
        ></span>
        <span
          class="w-[6px] h-[6px] rounded-full bg-[#cfd8dc] opacity-50 animate-[dot_1.2s_ease-in-out_0.3s_infinite]"
        ></span>
      </div>
    </div>

    <!-- Input Bar -->
    <div
      class="flex items-center gap-2 bg-[#1F2C33] px-[10px] py-2 border-t border-[rgba(255,255,255,.04)]"
      aria-hidden="true"
    >
      <span class="text-[1.05rem] opacity-85">😊</span>
      <div class="flex-1 bg-[#2A3942] text-[#8696a0] rounded-[24px] px-[14px] py-2 text-[0.82rem]">
        Mensagem
      </div>
      <span class="text-[1.05rem] opacity-85">📎</span>
      <!-- bg-primary allowed: mic button color matches neon green in the preview -->
      <span
        class="bg-primary text-primary-foreground w-[34px] h-[34px] rounded-full grid place-items-center text-[0.95rem] flex-none"
        >🎙️</span
      >
    </div>
  </div>
</div>
