---
import { footer } from '../lib/content';
---

<footer class="text-center text-[#888] text-[.85rem] py-[36px] px-5 pb-[44px] font-medium">
  <div class="inline-flex items-center gap-[10px] mb-3">
    <img
      src="/images/logo-icon.png"
      alt=""
      width="26"
      height="26"
      class="h-[26px] w-auto block"
      loading="lazy"
      decoding="async"
    />
    <img
      src="/images/logo-wordmark.png"
      alt="MeControla"
      width="85"
      height="17"
      class="h-[17px] w-auto block"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div>{footer.tagline}</div>
  <div class="text-[#888] text-[.78rem] mt-[6px]">{footer.legalLine}</div>
  <div class="text-[#888] text-[.78rem] mt-[4px]">© MeControla. Todos os direitos reservados.</div>
</footer>
