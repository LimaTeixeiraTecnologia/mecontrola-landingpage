---
import SectionHeader from '../ui/SectionHeader.astro';
import { methodology } from '../../lib/content';
---

<section
  id="metodologia"
  aria-labelledby="metodologia-heading"
  class="py-20 lg:py-28 bg-surface/30"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeader
      id="metodologia-heading"
      eyebrow="Como trabalhamos"
      title="Do diagnóstico à evolução contínua."
      align="center"
    />

    <div class="grid grid-cols-1 md:grid-cols-4 gap-0 relative">
      <div
        aria-hidden="true"
        class="hidden md:block absolute top-8 left-[12.5%] right-[12.5%] h-px bg-gradient-to-r from-primary via-accent to-primary opacity-30"
      >
      </div>

      {
        methodology.map((step) => (
          <div class="flex flex-col items-center text-center px-4 py-8 relative">
            <div class="relative mb-6">
              <div class="size-16 rounded-2xl border border-border bg-surface flex items-center justify-center z-10 relative">
                <span class="text-xl font-bold bg-gradient-to-br from-primary to-accent bg-clip-text text-transparent">
                  {step.number}
                </span>
              </div>
            </div>
            <h3 class="text-foreground font-semibold text-lg mb-3">{step.title}</h3>
            <p class="text-muted-foreground text-sm leading-relaxed">{step.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
