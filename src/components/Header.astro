---
// No props needed
---

<header class="sticky top-0 z-40 backdrop-blur bg-background/80 border-b border-border">
  <div class="max-w-[1080px] mx-auto px-5 flex items-center justify-between h-[64px]">
    <a href="/" class="inline-flex items-center gap-[10px] no-underline" aria-label="MeControla">
      <img
        src="/images/logo-icon.png"
        alt=""
        width="34"
        height="34"
        class="h-[34px] w-auto block"
        loading="eager"
        decoding="async"
      />
      <img
        src="/images/logo-wordmark.png"
        alt="MeControla"
        width="110"
        height="22"
        class="h-[22px] w-auto block"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav>
      <a
        href="#planos"
        data-track="cta_header_ver_planos"
        class="bg-primary text-primary-foreground font-bold rounded-full px-5 py-2.5 text-sm hover:shadow-glow-primary transition-all duration-150 no-underline"
      >
        Ver planos
      </a>
    </nav>
  </div>
</header>
